# Expo: EXPO_PUBLIC_* はバンドルに埋め込まれます（anon / publishable キーのみ使用）
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# 招待リンク用の公開ホスト（HTTPS）。本番/検証では必ず指定すること。
# 開発時は省略可（client-app/config.js のフォールバック値が使われる）。
EXPO_PUBLIC_SERVER_URL=https://invite.example.com

# これはテンプレートファイルなので実際の値は記入しないでください

# 省略可。メール確認のリダイレクト先（未設定時は expo-linking が scheme 付き URL を生成）
# Supabase Dashboard → Authentication → URL Configuration の Redirect URLs に同じ URL を追加すること
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT_TO=daibapp://auth/callback

# AdMob（F2-1 で導入）。テスト ID から本番 ID への切替は EAS プロファイルで分ける。
# EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_IOS_BANNER_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/ZZZZZZZZZZ
# EXPO_PUBLIC_ADMOB_ANDROID_BANNER_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/ZZZZZZZZZZ
# EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/WWWWWWWWWW

# Sentry（F2-4 で導入）
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
# EXPO_PUBLIC_APP_ENV=development  # development | preview | production

# RevenueCat（公開 SDK キーのみバンドル）。Supabase user id と App User ID を一致させる。
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxx
# IAP（F2-2）。商品 ID は App Store Connect / RevenueCat と整合させる。
# EXPO_PUBLIC_IAP_PRODUCT_ID_PREMIUM_MONTHLY=com.kytm1210.daibapp2026.premium.monthly
