{
  "expo": {
    "name": "daib-app",
    "slug": "daib-app",
    "scheme": "daib",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#E8E6E1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kytm1210.daibapp2026"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.kytm1210.daibapp2026",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "このアプリはQRコードを読み取るためにカメラを使用します。"
        }
      ],
      "expo-font"
    ]
  }
}
